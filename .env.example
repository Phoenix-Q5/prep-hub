# Postgres
POSTGRES_DB=prephub
POSTGRES_USER=prephub
POSTGRES_PASSWORD=prephub_dev_pw

# MinIO
MINIO_ROOT_USER=prephub
MINIO_ROOT_PASSWORD=prephub_dev_pw

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# App
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars_for_HS256
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Service URLs (when running app outside Docker, e.g. from IDE)
DB_URL=jdbc:postgresql://localhost:5432/prephub
ELASTICSEARCH_URI=http://localhost:9200
REDIS_HOST=localhost
REDIS_PORT=6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
JAEGER_ENDPOINT=http://localhost:4318/v1/traces

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
